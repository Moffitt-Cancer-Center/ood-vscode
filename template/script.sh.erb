#!/usr/bin/env bash

<%
# Set our working directory.
working_dir = Pathname.new(context.working_dir)

# Ensure that code-server always starts in either user defined directory or home directory.
if ! working_dir.exist?
	working_dir = Pathname.new(ENV['HOME'])
elsif working_dir.file?
	working_dir = working_dir.parent
end

# Make sure the working directory exists
%>
<%
  # ─── Custom Apptainer Build — process form values at submission time ─────────
  require 'yaml'
  require 'pathname'

  # Sanitize a candidate package name: only allow characters valid in
  # Debian/Ubuntu package names (alphanumeric, hyphens, periods, plus signs).
  # This prevents shell injection from user-supplied input.
  def _sanitize_pkg(name)
    name.to_s.strip.gsub(/[^a-zA-Z0-9\-\.+]/, "")
  end

  # custom_packages may come through as an Array (OOD multi-select) or as a
  # space-separated String depending on OOD version — handle both safely.
  _raw_custom = context.custom_packages rescue ""
  _selected_pkgs = [_raw_custom]
                     .flatten
                     .map(&:to_s)
                     .flat_map { |v| v.split(/\s+/) }
                     .map { |p| _sanitize_pkg(p) }
                     .reject(&:empty?)

  # extra_packages is a free-text field — split on spaces and/or commas.
  _extra_pkgs = context.extra_packages.to_s
                  .split(/[\s,]+/)
                  .map { |p| _sanitize_pkg(p) }
                  .reject(&:empty?)

  # Final deduplicated, sorted package list embedded into the script at submit time.
  _all_packages = (_selected_pkgs + _extra_pkgs).uniq.sort

  # Bypass flag: "1" → skip custom build and use base image directly.
  _bypass_build = context.bypass_custom_build.to_s.strip == "1"

  # ─── Append new free-text packages to the shared list ────────────────────────
  # This runs server-side at job submission time. Any package in _extra_pkgs
  # that is not already in data/packages.yml is appended so all users see it
  # in the dropdown on their next form load.
  #
  # Uses an exclusive flock for safe concurrent writes. The file is appended
  # as raw YAML text to preserve existing comments and formatting.
  # Failure is non-fatal — a logging issue must not block the user's job.
  if _extra_pkgs.any?
    _shared_pkg_file = Pathname.new(__FILE__).dirname.parent.join('data', 'packages.yml')
    if _shared_pkg_file.exist? && _shared_pkg_file.writable?
      begin
        File.open(_shared_pkg_file.to_s, File::RDWR) do |_f|
          _f.flock(File::LOCK_EX)
          _existing_data  = YAML.safe_load(_f.read) rescue nil
          _existing_pkgs  = (_existing_data.is_a?(Hash) ? (_existing_data['packages'] || []) : [])
                              .flat_map { |p| p['value'].to_s.split }
                              .map(&:strip)
          _new_pkgs = _extra_pkgs.reject { |p| _existing_pkgs.include?(p) }
          if _new_pkgs.any?
            _f.seek(0, IO::SEEK_END)
            _new_pkgs.each do |_pkg|
              # Append a minimal curated entry. Admin can later add a richer
              # label by editing data/packages.yml directly.
              _f.write("  - label: #{_pkg.inspect}\n    value: #{_pkg.inspect}\n")
            end
          end
        end
      rescue
        # Non-fatal: a write failure must not prevent the job from starting.
      end
    end
  end
%>
mkdir -p "<%= working_dir %>"

##################################################################
#- Function definitions
##################################################################
create_log_config() {
	LOG_CF=$1
	if [ ! -f "$LOG_CF" ]; then
		printf "[*]\nlogger-type=file\nlog-dir=/var/log/code-server\n" > ${LOG_CF}
		printf "log-level=info\n" >> ${LOG_CF}
	fi
}
check_conda_config() {
	if [ -z "<%= context.auto_conda %>" ]; then
		# No conda environment selected
		export CONDA_ENV=""
		return 0
	fi
	
	dirs=("$HOME/.conda/envs" "$HOME/miniconda3/envs" "$HOME/anaconda3/envs")
	for dir in "${dirs[@]}"; do
		if [ -d "$dir/<%= context.auto_conda %>" ]; then
			export CONDA_ENV="$dir/<%= context.auto_conda %>"
			echo "Found $CONDA_ENV"
			return 0
		fi
	done
	echo "'<%= context.auto_conda %>' not found in specified directories."
	return 1
}

###################################################################
ROOT_DIR="<%= session.staged_root %>"
V_VERSION="<%= context.v_version %>"
V_MEM="<%= context.auto_mem %>G"
LOG_DIR="${ROOT_DIR}/log"
BIN_DIR="${ROOT_DIR}/bin"
TMP_DIR=$(mktemp -d)
JOB_LOG="${LOG_DIR}/job_startup.log"
VSCODE_DIR=${HOME}/.local/share/code_server
VSCODE_EXT=${VSCODE_DIR}/extensions
VSCODE_VAR_LIB=${VSCODE_DIR}/var/lib
VSCODE_VAR_RUN=${ROOT_DIR}/var/run
VSCODE_OPT=${VSCODE_DIR}/opt
VSCODE_ETC=${VSCODE_DIR}/etc
VSCODE_VAR_LOG=${LOG_DIR}

# "APPTAINERENV" must preceed anything exported to apptainer environment.
export APPTAINERENV_VSCODE_PASSWORD="$password"
export VSCODE_PASSWORD="$password"
export PASSWORD="$password"

case "$V_VERSION" in
    "moffitt-ml")
        export VSCODE_CONTAINER_URI="docker://dockerhub.moffitt.org/ood/rocker-multi:latest"
        ;;
    "rocker-ml")
        export VSCODE_CONTAINER_URI="docker://docker.io/rocker/ml:latest"
        ;;
esac

# Initialize environment for execution.
mkdir -p ${LOG_DIR}
echo "`date`: Initializing VSCode environment" >> ${JOB_LOG}
echo "`date`: VSCode Version $V_VERSION" >> ${JOB_LOG}
echo "`date`: Using docker URI $VSCODE_CONTAINER_URI" >> ${JOB_LOG}

# setup_env
setup_env () {
  source /etc/profile.d/modules.sh
  export MODULEPATH=$MODULEPATH:/app/eb/modules/all:/app/other/modules
  module purge
}
create_env_config() {
  ENV_FILE="$VSCODE_ETC/env-vscode/env"

  if [[ ! -f "$ENV_FILE" ]]; then
    ENV_DIR="$VSCODE_ETC/env-vscode"

    mkdir -p "$ENV_DIR" || { echo "Failed to create directory $ENV_DIR"; exit 1; }
    touch "$ENV_FILE"
    chmod 770 "$ENV_DIR" || { echo "Failed to set permissions for $ENV_DIR"; exit 1; }

    # If the file is empty, initialize it
    if [[ ! -s "$ENV_FILE" ]]; then
      echo 'export REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt' > "$ENV_FILE"
      echo 'export SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt' >> "$ENV_FILE"
      echo 'export NODE_EXTRA_CA_CERTS=/etc/ssl/certs/ca-certificates.crt' >> "$ENV_FILE"
    fi
  fi
}
setup_env

####################################################################
#- workspace_init
mkdir -p -m 700 \
	"${VSCODE_DIR}/extensions" \
	"${VSCODE_ETC}" \
	"${VSCODE_OPT}" \
	"${VSCODE_VAR_LOG}" \
	"${VSCODE_VAR_LIB}" \
	"${VSCODE_VAR_RUN}"
touch "${VSCODE_VAR_RUN}/code-server.pid"
create_log_config "${VSCODE_ETC}/logging.conf"
check_conda_config
create_env_config

# Unset any current variables the user may have set for their RedHat shell in favor of the container's Ubuntu shell, then set the appropriate variables for Ubuntu.
#unset REQUESTS_CA_BUNDLE
#unset SSL_CERT_FILE
#unset NODE_EXTRA_CA_CERTS

source $ENV_FILE

####################################################################
#- custom_build
# Optionally build a user-customized Apptainer container with extra Ubuntu
# packages.  Values were sanitized at OOD submit time (ERB stage).
#
# Behaviour:
#   - If bypass_custom_build is checked, skip entirely and use the base image.
#   - If no packages were requested, skip and use the base image.
#   - Otherwise, write (or update) an Apptainer .def file in the user's
#     ~/.local/share/code_server/custom-build/ directory, then build a .sif.
#   - The build is cached via a hash of (base_image + package_list) stored in
#     a sidecar .hash file — rebuild only when the hash changes.
#   - On build failure the job exits so the user sees a clear error rather
#     than a silent fallback to the base image.

BYPASS_CUSTOM_BUILD="<%= _bypass_build ? "1" : "0" %>"
ALL_PACKAGES="<%= _all_packages.join(" ") %>"
CUSTOM_BUILD_DIR="${HOME}/.local/share/code_server/custom-build"
CUSTOM_DEF_FILE="${CUSTOM_BUILD_DIR}/vscode-custom.def"
CUSTOM_SIF_FILE="${CUSTOM_BUILD_DIR}/vscode-custom.sif"
CUSTOM_HASH_FILE="${CUSTOM_BUILD_DIR}/vscode-custom.hash"

echo "`date`: Custom build bypass flag: ${BYPASS_CUSTOM_BUILD}" >> ${JOB_LOG}
echo "`date`: Requested custom packages: ${ALL_PACKAGES:-none}" >> ${JOB_LOG}

if [[ "${BYPASS_CUSTOM_BUILD}" != "1" && -n "${ALL_PACKAGES}" ]]; then
  # Strip the docker:// scheme prefix to produce the bare image reference
  # used in the Apptainer .def file's "From:" line.
  BASE_IMAGE="${VSCODE_CONTAINER_URI#docker://}"

  # Deterministic hash: base image URI + sorted package list.
  # Any change to either component triggers a rebuild.
  CURRENT_HASH=$(printf '%s %s' "${VSCODE_CONTAINER_URI}" "${ALL_PACKAGES}" \
                   | md5sum | cut -d' ' -f1)

  NEED_BUILD=1
  if [[ -f "${CUSTOM_SIF_FILE}" && -f "${CUSTOM_HASH_FILE}" ]]; then
    STORED_HASH=$(cat "${CUSTOM_HASH_FILE}" 2>/dev/null || echo "")
    if [[ "${STORED_HASH}" == "${CURRENT_HASH}" ]]; then
      echo "`date`: Custom container cache is valid (hash: ${CURRENT_HASH}) — skipping build" >> ${JOB_LOG}
      NEED_BUILD=0
    else
      echo "`date`: Package list or base image changed — will rebuild" >> ${JOB_LOG}
      echo "`date`:   stored hash : ${STORED_HASH}" >> ${JOB_LOG}
      echo "`date`:   current hash: ${CURRENT_HASH}" >> ${JOB_LOG}
    fi
  else
    echo "`date`: No cached custom container found — building for the first time" >> ${JOB_LOG}
  fi

  if [[ "${NEED_BUILD}" == "1" ]]; then
    mkdir -p -m 700 "${CUSTOM_BUILD_DIR}"

    # Write the Apptainer definition file.  The user can further edit this
    # file at ~/.local/share/code_server/custom-build/vscode-custom.def between
    # sessions.  The hash-based cache will detect form-value changes and trigger
    # a rebuild accordingly.
    cat > "${CUSTOM_DEF_FILE}" << 'APPTAINER_DEF_SENTINEL'
# Apptainer definition file — generated by the VSCode OOD app.
# Location: ~/.local/share/code_server/custom-build/vscode-custom.def
# You may inspect this file or extend the %post section, but note that the
# OOD app regenerates it when the form values change.
APPTAINER_DEF_SENTINEL

    # Append the dynamic portion (variable-expanded, so not single-quoted).
    cat >> "${CUSTOM_DEF_FILE}" << APPTAINER_DEF_EOF
Bootstrap: docker
From: ${BASE_IMAGE}

%post
    apt-get update -qq
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends --fix-missing \
        ${ALL_PACKAGES}
    apt-get clean
    rm -rf /var/lib/apt/lists/*
APPTAINER_DEF_EOF

    chmod 600 "${CUSTOM_DEF_FILE}"
    echo "`date`: Apptainer .def written to: ${CUSTOM_DEF_FILE}" >> ${JOB_LOG}
    echo "`date`: Base image : ${BASE_IMAGE}" >> ${JOB_LOG}
    echo "`date`: Packages   : ${ALL_PACKAGES}" >> ${JOB_LOG}

    echo "Building custom VSCode container (base: ${BASE_IMAGE}, packages: ${ALL_PACKAGES})"
    echo "  This may take 20-60 minutes for large images on the first build."
    echo "  Progress is logged to: ${JOB_LOG}"
    echo "  To check progress: tail -f ${JOB_LOG}"
    echo "`date`: Building custom container — this may take several minutes on first build..." >> ${JOB_LOG}

    # Remove stale artifacts before building.
    rm -f "${CUSTOM_SIF_FILE}" "${CUSTOM_HASH_FILE}"

    if apptainer build --fakeroot --force \
         "${CUSTOM_SIF_FILE}" "${CUSTOM_DEF_FILE}" >> "${JOB_LOG}" 2>&1; then
      printf '%s' "${CURRENT_HASH}" > "${CUSTOM_HASH_FILE}"
      chmod 600 "${CUSTOM_HASH_FILE}"
      echo "`date`: Custom container built successfully: ${CUSTOM_SIF_FILE}" >> ${JOB_LOG}
      echo "Custom container build complete."
    else
      echo "`date`: ERROR: Custom Apptainer build failed." >> ${JOB_LOG}
      echo "ERROR: Custom Apptainer build failed."
      echo "  Definition file : ${CUSTOM_DEF_FILE}"
      echo "  Job log         : ${JOB_LOG}"
      echo "  To recover, re-submit the job with 'Bypass custom container build' checked."
      exit 1
    fi
  fi

  # Switch to the custom image for this session.
  VSCODE_CONTAINER_URI="${CUSTOM_SIF_FILE}"
  echo "`date`: Using custom container: ${VSCODE_CONTAINER_URI}" >> ${JOB_LOG}

else
  if [[ "${BYPASS_CUSTOM_BUILD}" == "1" ]]; then
    echo "`date`: Custom build bypassed — using base image: ${VSCODE_CONTAINER_URI}" >> ${JOB_LOG}
  else
    echo "`date`: No custom packages requested — using base image: ${VSCODE_CONTAINER_URI}" >> ${JOB_LOG}
  fi
fi

# Validate conda environment if specified
if [ -n "$CONDA_ENV" ]; then
  if [ ! -d "$CONDA_ENV" ]; then
    echo "`date`: ERROR: Conda environment '$CONDA_ENV' not found!" >> ${JOB_LOG}
    exit 1
  fi
  echo "`date`: Using conda environment: $CONDA_ENV" >> ${JOB_LOG}
fi

########################################
# apptainer variables
# https://apptainer.org/docs/user/main/cli/apptainer_exec.html

BIND_POINTS=""\
"${VSCODE_ETC}/logging.conf:/etc/code-server/logging.conf,"\
"${VSCODE_VAR_LOG}:/var/log/code-server,"\
"${VSCODE_VAR_LIB}:/var/lib/code-server,"\
"${VSCODE_VAR_RUN}:/run/code-server,"\
"${VSCODE_OPT}:/opt/share,"\
"${TMP_DIR}:/tmp"

# Add conda environment binding if selected
if [ -n "$CONDA_ENV" ]; then
  BIND_POINTS="${BIND_POINTS},${CONDA_ENV}:/opt/share/code-server/conda"
fi

echo "`date`: Bind points for container:" >> ${JOB_LOG}
echo "$BIND_POINTS" | tr ',' '\n' >> ${JOB_LOG}

###########################
# Launch the Code Server

# Set working directory to home directory
cd "${HOME}"

# Output debug info
printf "`date`: Module list\n\t" >> ${JOB_LOG}
module list 2>> ${JOB_LOG}
echo "`date`: Executing VSCode on `hostname`." >> ${JOB_LOG}
echo "`date`: Starting up VSCode..." >> ${JOB_LOG}

# Container startup
apptainer exec \
	--nv \
	--hostname "vscode-$(hostname)-${SESSION_ID}" \
	--fakeroot \
	-B "${BIND_POINTS}" \
	"$VSCODE_CONTAINER_URI" \
	code-server \
	--auth="password" \
	--bind-addr="0.0.0.0:${port}" \
	--disable-telemetry \
	--user-data-dir="$VSCODE_DIR" \
	--log debug \
	"<%= working_dir.to_s %>" || {
		echo "`date`: Failed to start VSCode container" >> ${JOB_LOG}
		exit 1
	}
